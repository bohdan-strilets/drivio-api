<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        color: #18181b;
        background-color: #f4f4f5;
      }
      .body p {
        margin: 0 0 16px;
      }
      .body p:last-child {
        margin-bottom: 0;
      }
    </style>
  </head>
  <body
    style='margin:0; padding:0; font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; font-size:16px; line-height:1.5; color:#18181b; background-color:#f4f4f5;'
  >
    <table
      width='100%'
      cellpadding='0'
      cellspacing='0'
      role='presentation'
      style='border-collapse:collapse; background-color:#f4f4f5;'
    >
      <tr>
        <td align='center' style='padding: 20px 16px;'>
          <table
            width='560'
            cellpadding='0'
            cellspacing='0'
            role='presentation'
            style='border-collapse:collapse; max-width:560px; background-color:#ffffff; border-radius:8px; border:1px solid #e4e4e7;'
          >
            {{#if showHeader}}
              <tr>
                <td
                  style='padding: 20px 20px 16px; border-bottom: 1px solid #e4e4e7;'
                >
                  <h1
                    style='margin:0; font-size:20px; font-weight:600;'
                  >{{title}}</h1>
                </td>
              </tr>
            {{/if}}
            <tr>
              <td class='body' style='padding: 20px;'>
                {{{body}}}
              </td>
            </tr>
            {{#if showFooter}}
              <tr>
                <td
                  style='padding: 16px 20px; font-size: 12px; color: #71717a; border-top: 1px solid #e4e4e7;'
                >
                  Drivio<br />
                  © 2026 Drivio
                </td>
              </tr>
            {{/if}}
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
